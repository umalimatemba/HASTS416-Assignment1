P_A <- matrix(c(0.4,0.4,0.2, 0.3,0.4,0.3, 0,0.1,0.9), nrow=3, byrow=TRUE)
P_B <- matrix(c(0.1,0.5,0.4, 0.1,0.3,0.6, 0,0.1,0.9), nrow=3, byrow=TRUE)
library(expm)
pi_1pm <- c(1, 0, 0)
pi_4pm <- pi_1pm %*% (P_A %^% 9)
pi_6pm <- pi_4pm %*% (P_B %^% 6)
cat("Distribution at 4PM:", round(pi_4pm,4), " ")
cat("Distribution at 6PM:", round(pi_6pm,4), " ")
